# 复制本文件为 .env 并填入你的真实 Webhook 地址
# Windows 计划任务会自动读取同目录下的 .env 文件（如需要可自行扩展）

# 机器人 Webhook 地址（必填）
# 企业微信示例: https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# 飞书示例: https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# 钉钉示例: https://oapi.dingtalk.com/robot/send?access_token=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WEBHOOK_URL=

# 机器人类型（可选，默认 wechat）
# 支持: wechat / feishu / dingtalk
# 注意：只有企业微信(wechat)支持直接发送本地图片，其他平台仅发送文字
WEBHOOK_TYPE=wechat
